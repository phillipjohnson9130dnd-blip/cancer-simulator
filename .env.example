# ── LLM provider ─────────────────────────────────────────────────────────────
# Choose one: groq (free cloud) | anthropic (Claude) | openai (Ollama / any
# OpenAI-compatible endpoint). Default is groq.
LLM_PROVIDER=groq

# ── Groq (free) — get a key at https://console.groq.com/keys ─────────────────
GROQ_API_KEY=your_groq_key_here
# Optional: override the model. See https://console.groq.com/docs/models
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Anthropic (only if LLM_PROVIDER=anthropic) ───────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Local / OpenAI-compatible (only if LLM_PROVIDER=openai) ──────────────────
# For Ollama (free, local): install from https://ollama.com, run `ollama pull llama3.2:3b`
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3.2:3b
# OPENAI_API_KEY=not-needed

PORT=3001
